{
    "name": "@codemind.ec/medusa-plugin-invoice",
    "version": "1.0.6",
    "description": "Invoice & quotation PDF widget for Medusa v2 admin — download order receipts and manage company billing config.",
    "author": "Kollor <dev@codemind.ec> (https://codemind.ec)",
    "license": "MIT",
    "files": [
        ".medusa/server",
        "index.d.ts"
    ],
    "types": "./index.d.ts",
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "default": "./.medusa/server/src/index.js"
        },
        "./package.json": "./package.json",
        "./modules/invoice-generator": {
            "types": "./index.d.ts",
            "default": "./.medusa/server/src/modules/invoice-generator/index.js"
        },
        "./modules/*": "./.medusa/server/src/modules/*/index.js",
        "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
        "./admin": {
            "import": "./.medusa/server/src/admin/index.mjs",
            "require": "./.medusa/server/src/admin/index.js",
            "default": "./.medusa/server/src/admin/index.js"
        }
    },
    "keywords": [
        "medusa",
        "medusa-plugin",
        "medusa-v2",
        "plugin",
        "invoice",
        "pdf",
        "comprobante",
        "codemind",
        "kollor"
    ],
    "scripts": {
        "build": "medusa plugin:build",
        "dev": "medusa plugin:develop",
        "prepublishOnly": "medusa plugin:build"
    },
    "devDependencies": {
        "@medusajs/admin-sdk": "2.13.3",
        "@medusajs/admin-shared": "2.13.3",
        "@medusajs/cli": "2.13.3",
        "@medusajs/framework": "2.13.3",
        "@medusajs/icons": "^2.13.3",
        "@medusajs/js-sdk": "^2.13.3",
        "@medusajs/medusa": "2.13.3",
        "@medusajs/test-utils": "2.13.3",
        "@medusajs/ui": "^4.1.3",
        "@swc/core": "^1.7.28",
        "@tanstack/react-query": "^5.64.2",
        "@types/node": "^20",
        "@types/pdfmake": "^0.2.11",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "handlebars": "^4.7.8",
        "prop-types": "^15.8.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-hook-form": "^7.54.2",
        "ts-node": "^10.9.2",
        "typescript": "^5",
        "vite": "^5.4.14"
    },
    "dependencies": {
        "@codemirror/lang-html": "^6.4.11",
        "@codemirror/theme-one-dark": "^6.1.3",
        "@uiw/react-codemirror": "^4.25.8",
        "axios": "^1.7.7",
        "pdfmake": "^0.2.20",
        "puppeteer-core": "^24.0.0"
    },
    "peerDependencies": {
        "@medusajs/admin-sdk": "2.13.3",
        "@medusajs/cli": "2.13.3",
        "@medusajs/framework": "2.13.3",
        "@medusajs/icons": "^2.13.3",
        "@medusajs/medusa": "2.13.3",
        "@medusajs/test-utils": "2.13.3",
        "@medusajs/ui": "^4.1.3"
    },
    "engines": {
        "node": ">=20"
    }
}
